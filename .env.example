# === REQUIRED ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_ID=your_telegram_id_here

# === AI PROVIDER ===
# openai | deepseek
AI_PROVIDER=deepseek
OPENAI_API_KEY=
DEEPSEEK_API_KEY=your_deepseek_key_here
AI_MODEL_PRIMARY=deepseek-chat
AI_MODEL_FALLBACK=deepseek-chat

# === DATABASE ===
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=quiz_bot
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# === REDIS ===
REDIS_URL=redis://redis:6379/0

# === PAYMENTS (ixtiyoriy) ===
PAYME_MERCHANT_ID=
PAYME_KEY=
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
STRIPE_SECRET_KEY=

# === SERVICE PORTS ===
GATEWAY_PORT=8080
BOT_PORT=8000
GAME_PORT=8081
AI_ENGINE_PORT=8002
SUBSCRIPTION_PORT=8003
ADMIN_API_PORT=8004

# === OPTIONAL ===
LOG_LEVEL=info
AI_MAX_CONCURRENT=3

# === ADMIN API ===
ADMIN_SECRET=your-secret-token-here
ADMIN_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
