# ============================================================
# AIQuizly — Environment Variables (.env.example)
# Nusxalang: cp .env.example .env
# Keyin haqiqiy qiymatlarni to'ldiring.
# ============================================================

# ─────────────────── MAJBURIY ───────────────────

# Telegram bot tokeni (@BotFather dan olinadi)
TELEGRAM_BOT_TOKEN=8657778296:AAE...

# OpenAI API key (GPT-4o-mini uchun)
OPENAI_API_KEY=sk-...

# PostgreSQL ulanish URL
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/quiz_bot

# Redis URL
# DB0 — cache, DB1 — bot sessions, DB2 — Celery + notifier queue
REDIS_URL=redis://localhost:6379/0

# ─────────────────── TO'LOV TIZIMLARI ───────────────────

# Payme (ixtiyoriy)
PAYME_MERCHANT_ID=
PAYME_KEY=

# Click (ixtiyoriy)
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# Stripe (ixtiyoriy)
STRIPE_SECRET_KEY=

# ─────────────────── SERVIS PORTLARI ───────────────────

# Gateway (Nginx/reverse proxy uchun asosiy kirish nuqtasi)
GATEWAY_PORT=8080

# Bot webhook server
BOT_PORT=8000

# Game service (Go)
GAME_PORT=8081

# AI Engine (fayl qayta ishlash)
AI_ENGINE_PORT=8002

# Subscription service (limit + to'lov)
SUBSCRIPTION_PORT=8003

# Admin API
ADMIN_API_PORT=8004

# Notifier (Go, Redis orqali)
NOTIFIER_PORT=8082

# ─────────────────── SERVIS ICHKI URLlari ───────────────────
# Docker Compose da servis nomlari ishlatiladi (localhost emas)

GAME_SERVICE_URL=http://game:8081
AI_ENGINE_URL=http://ai-engine:8002
SUBSCRIPTION_URL=http://subscription:8003
NOTIFIER_URL=http://notifier:8082

# ─────────────────── ADMIN ───────────────────

# Admin API token (X-Admin-Token header)
ADMIN_TOKEN=change-me-strong-secret-token

# ─────────────────── IXTIYORIY ───────────────────

# Log darajasi: debug | info | warn | error
LOG_LEVEL=info

# Muhit: development | production
ENVIRONMENT=development

# Sentry DSN (xatoliklarni kuzatish uchun, ixtiyoriy)
SENTRY_DSN=

# CORS ruxsat etilgan originlar (admin panel uchun)
CORS_ORIGINS=http://localhost:3000

# Webhook URL (production da to'liq HTTPS URL bo'lishi kerak)
# WEBHOOK_URL=https://your-domain.com/webhook

# Max fayl hajmi (MB)
MAX_FILE_SIZE_MB=10
